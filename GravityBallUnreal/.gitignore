# Temporary / backup files
############################################

*.tmp
*.temp
*.bak
*.old
*.backup
*.swp
*.swo

############################################
# Compression / archives
############################################

*.zip
*.7z
*.rar
*.tar
*.gz

############################################
# Unreal Engine shader cache
############################################

ShaderCache/
*.ushadercache
*.shadercache

############################################
# Unreal Engine asset thumbnails
############################################

*_BuiltData.uasset

############################################
# Python / scripting cache (if used)
############################################

__pycache__/
*.pyc

############################################
# Ignore local config overrides
############################################

# Keep Default*.ini, ignore local overrides
Config/*.ini
!Config/Default*.ini
