############################################
# Unreal Engine
############################################

# Compiled binaries
Binaries/
Win64/
Win32/
Linux/
Mac/
Android/
IOS/

# Build results
Build/
Builds/

# Derived data & caches
DerivedDataCache/
Intermediate/
Saved/

# Unreal Editor autosaves & backups
Saved/Autosaves/
Saved/Backup/
Saved/Config/CrashReportClient/
Saved/Logs/
Saved/Temp/

# Local user/editor settings
Saved/Config/WindowsEditor/
Saved/Config/LinuxEditor/
Saved/Config/MacEditor/

############################################
# Unreal Engine generated files
############################################

# Visual Studio / IDE files generated by UE
.vs/
.vscode/
.idea/

# VS project files
*.VC.db
*.VC.opendb
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.vcxproj.DotSettings
*.opensdf
*.sdf
*.suo
*.user
*.userprefs

# Xcode
*.xcodeproj
*.xcworkspace
*.xcuserdata/

# Rider
*.sln.iml
.idea/

############################################
# Unreal Engine plugins
############################################

# Plugin intermediate & binaries
Plugins/*/Binaries/
Plugins/*/Intermediate/
Plugins/*/Saved/

############################################
# Unreal Engine packaging & cooking
############################################

# Cooked / packaged builds
Saved/Cooked/
Saved/StagedBuilds/

############################################
# Unreal Engine crash reports
############################################

crashinfo-*
CrashReportClient/

############################################
# Logs
############################################

*.log

############################################
# OS-generated files
############################################

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Linux
*~

